{
  "name": "sudoku-display",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "wasm:build": "wasm-pack build rust/sudoku_generator --target web --out-dir ../../public/wasm/pkg",
    "wasm:verify": "node tools/verify-wasm-externref-table.mjs",
    "build": "npm run wasm:build && npm run wasm:verify && tsc -b && vite build",
    "preview": "vite preview",
    "lint:breakpoints": "node tools/lint-breakpoint-sync.mjs",
    "lint:typography": "node tools/lint-typography-tokens.mjs",
    "lint:spacing": "node tools/lint-spacing-tokens.mjs",
    "lint:styles": "npm run lint:breakpoints && npm run lint:typography && npm run lint:spacing",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
